{
  "name": "ssh-envoy",
  "displayName": "SSH Envoy",
  "publisher": "zarulizham",
  "description": "Start ssh server using Envoy.blade.php servers",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zarulizham/ssh-envoy-vscode-ext.git"
  },
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ssh-envoy",
          "title": "SSH Envoy",
          "icon": "resources/envoy.svg"
        }
      ]
    },
    "views": {
      "ssh-envoy": [
        {
          "id": "sshEnvoyServers",
          "name": "Servers"
        }
      ]
    },
    "commands": [
      {
        "command": "ssh-envoy.connect",
        "title": "Connect via SSH",
        "icon": "$(remote)"
      },
      {
        "command": "ssh-envoy.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ssh-envoy.refresh",
          "when": "view == sshEnvoyServers",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "ssh-envoy.connect",
          "when": "view == sshEnvoyServers && viewItem == envoyServer",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.116.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}